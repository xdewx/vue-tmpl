{
  "name": "@leoking/vue-tmpl",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "files": [
    "lib",
    "eslint.config.js",
    "auto-imports.d.ts",
    "components.d.ts",
    "tsconfig.lib.json"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.es.js"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.cjs"
      }
    },
    "./*": "./lib/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:hash": "cross-env VITE_ROUTER_MODE=hash bun run build",
    "build:lib": "vite build --config vite.config.lib.ts && vue-tsc -p tsconfig.lib.json",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "prepare": "husky",
    "prepublishOnly": "bun run build:lib",
    "release": "release-it",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "dev:all": "npm-run-all --parallel dev storybook"
  },
  "dependencies": {
    "@ipa-schema/api": "^0.0.12",
    "@vueuse/core": "^14.2.1",
    "@vueuse/math": "^14.2.1",
    "lodash-es": "^4.17.23",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@tauri-apps/cli": "^2.10.0",
    "@types/bun": "latest",
    "@unocss/eslint-config": "^66.5.9",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue-macros/eslint-config": "^3.1.1",
    "@vueuse/head": "^2.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "prettier": "^3.6.2",
    "release-it": "^19.2.4",
    "sass-embedded": "^1.97.3",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.3.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.47.0",
    "unocss": "^66.6.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "bun run format:check && bun run lint",
    "preserveUnused": true
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
